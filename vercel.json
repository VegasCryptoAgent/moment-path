{
  "version": 2,
  "cleanUrls": false,
  "headers": [
    {
      "source": "/assets/(.*).mp4",
      "headers": [
        { "key": "Content-Type", "value": "video/mp4" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets/|js/|css/|images/|fonts/|favicon/|manifest\\.json|robots\\.txt).*)", "destination": "/index.html" }
  ]
}
